{
  "name": "@okf-harness/cli",
  "version": "0.0.0",
  "description": "The okfh command-line package.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "okfh": "./dist/main.js",
    "okf-harness": "./dist/main.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm --dir ../.. --filter @okf-harness/core build && tsup src/index.ts src/main.ts --format esm --dts --clean"
  },
  "dependencies": {
    "@okf-harness/agent-pack": "workspace:*",
    "@okf-harness/core": "workspace:*",
    "commander": "4.1.1"
  }
}
