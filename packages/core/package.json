{
  "name": "@okf-harness/core",
  "version": "0.0.0",
  "description": "OKF parsing, config, manifest, path safety, lint, search, graph, and source handling.",
  "license": "Apache-2.0",
  "type": "module",
  "author": "Eric Zhou",
  "homepage": "https://github.com/pumblus/okf-harness#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pumblus/okf-harness.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/pumblus/okf-harness/issues"
  },
  "keywords": [
    "okf",
    "open-knowledge-format",
    "llm-wiki",
    "markdown",
    "local-first",
    "knowledge-management"
  ],
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.3"
  }
}
